{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      ".read": "auth != null",
      ".indexOn": ["createdAt"],
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.exists() && (newData.child('players/white').val() === auth.uid || newData.child('players/black').val() === auth.uid)) || (data.exists() && !newData.exists() && (data.child('players/white').val() === auth.uid || data.child('players/black').val() === auth.uid || !data.child('createdAt').isNumber() || data.child('createdAt').val() < now - 86400000)))",
        ".validate": "newData.hasChildren(['createdAt', 'status', 'players', 'fen'])",
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "endedAt": {
          ".write": "auth != null && (data.parent().child('players/white').val() === auth.uid || data.parent().child('players/black').val() === auth.uid)",
          ".validate": "newData.isNumber()"
        },
        "lastMoveAt": {
          ".write": "auth != null && (data.parent().child('players/white').val() === auth.uid || data.parent().child('players/black').val() === auth.uid)",
          ".validate": "newData.isNumber()"
        },
        "status": {
          ".write": "auth != null && (data.parent().child('players/white').val() === auth.uid || data.parent().child('players/black').val() === auth.uid)",
          ".validate": "newData.val() === 'waiting' || newData.val() === 'playing'"
        },
        "players": {
          "$side": {
            ".write": "auth != null && !data.exists() && newData.val() === auth.uid",
            ".validate": "($side === 'white' || $side === 'black') && newData.isString()"
          }
        },
        "fen": {
          ".write": "auth != null && (data.parent().child('players/white').val() === auth.uid || data.parent().child('players/black').val() === auth.uid)",
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "round": {
          ".write": "auth != null && (data.parent().child('players/white').val() === auth.uid || data.parent().child('players/black').val() === auth.uid)",
          ".validate": "newData.isNumber() && (data.exists() ? newData.val() === data.val() + 1 : newData.val() === 2)"
        },
        "rematch": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid && (data.parent().parent().child('players/white').val() === auth.uid || data.parent().parent().child('players/black').val() === auth.uid)",
            ".validate": "newData.isNumber()"
          }
        },
        "moves": {
          "$round": {
            "$moveId": {
              ".write": "auth != null && !data.exists() && newData.exists() && (data.parent().parent().parent().child('players/white').val() === auth.uid || data.parent().parent().parent().child('players/black').val() === auth.uid)",
              ".validate": "newData.hasChildren(['uci', 'side']) && data.parent().parent().parent().child('players/' + newData.child('side').val()).val() === auth.uid",
              "uci": {
                ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 5"
              },
              "side": {
                ".validate": "newData.val() === 'white' || newData.val() === 'black'"
              },
              "$other": {
                ".validate": false
              }
            }
          }
        },
        "resignedBy": {
          ".write": "auth != null && (newData.exists() ? data.parent().child('players/' + newData.val()).val() === auth.uid : (data.parent().child('players/white').val() === auth.uid || data.parent().child('players/black').val() === auth.uid))",
          ".validate": "newData.val() === 'white' || newData.val() === 'black'"
        },
        "presence": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid",
            ".validate": "newData.isBoolean()"
          }
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "matchmaking": {
      "waiting": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.child('uid').val() === auth.uid) || (data.exists() && !newData.exists()))",
        ".validate": "newData.hasChildren(['uid', 'roomId', 'createdAt'])",
        "uid": {
          ".validate": "newData.val() === auth.uid"
        },
        "roomId": {
          ".validate": "newData.isString() && newData.val().length === 6"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
